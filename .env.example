# Job Pipeline — local environment template
# Copy to `.env` and adjust as needed:
#   cp .env.example .env
#
# No real secrets needed for local LLM operation.
# Google Sheets OAuth2 credentials are configured inside n8n's UI,
# not via env vars.

# ---------- Ollama (LLM service) ----------
# URL where jobspy reaches Ollama. Use container name on Docker network.
OLLAMA_URL=http://ollama:11434

# Which model to use for scoring. Pulled via `ollama pull <model>`.
# Other options: llama3.1:8b (slower, sharper), qwen2.5:3b, etc.
OLLAMA_MODEL=llama3.2:3b

# Per-call HTTP timeout, in seconds. Generous default; rarely hit.
OLLAMA_TIMEOUT=120

# How many concurrent inferences jobspy allows via the asyncio semaphore.
# Tune for your machine's RAM. 3 is comfortable on 8 GB.
OLLAMA_CONCURRENCY=3

# ---------- Ollama (passed directly to ollama container) ----------
# How many concurrent requests Ollama itself will accept. Should match
# OLLAMA_CONCURRENCY above.
OLLAMA_NUM_PARALLEL=3

# How long Ollama keeps the model loaded in RAM after a request.
# 30m avoids cold-starts during long batch runs.
OLLAMA_KEEP_ALIVE=30m

# ---------- jobspy ↔ n8n ----------
# Used by n8n nodes to reach jobspy. Container-network address.
JOBSPY_URL=http://jobspy:8000

# ---------- n8n ----------
# Timezone for scheduled triggers and timestamps.
GENERIC_TIMEZONE=Europe/Dublin
TZ=Europe/Dublin

# Set to false for local dev (HTTP only). Set to true behind HTTPS.
N8N_SECURE_COOKIE=false
